# ============================================================
# THE INDEPENDENCE LAW FIRM — CLIENT PORTAL
# Environment Variables — Copy to .env.local and fill in values
# NEVER commit .env.local to version control
# ============================================================

# ── Application ─────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-jwt-key-minimum-32-chars

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (Supabase, Neon, PlanetScale, etc.)
DATABASE_URL=postgresql://user:password@host:5432/independence_law_portal

# ── Email / SMTP ─────────────────────────────────────────────
# Used for sending email verification links
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@theindependencelaw.com
SMTP_PASS=your-smtp-password

# Email sender identity
EMAIL_FROM_NAME=The Independence Law Firm
EMAIL_FROM_ADDRESS=noreply@theindependencelaw.com

# ── Email Verification ───────────────────────────────────────
# Token expiry in seconds (default: 86400 = 24 hours)
EMAIL_VERIFY_TOKEN_EXPIRY=86400

# ── Encryption ───────────────────────────────────────────────
# Used for hashing verification tokens
# Generate with: openssl rand -base64 32
TOKEN_SECRET=your-token-secret-for-verification-hashing

# ── Admin Authentication (Role-Isolated) ─────────────────────
# Admin credentials are NEVER stored in the database.
# Only hashed credentials are stored here in env vars.
#
# ADMIN_EMAIL: the administrator's login email
ADMIN_EMAIL=admin@theindependencelaw.com
#
# ADMIN_PASSWORD_HASH: bcrypt hash of the admin password (cost factor 12)
# Generate with:
#   node -e "require('bcryptjs').hash('your-strong-password', 12).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$12$CHANGE_ME_run_the_node_command_above_to_generate
#
# ADMIN_JWT_SECRET: signs admin session tokens — MUST be different from NEXTAUTH_SECRET
# A client token signed with NEXTAUTH_SECRET cannot access admin routes.
# Generate with: openssl rand -base64 32
ADMIN_JWT_SECRET=your-separate-admin-jwt-secret-minimum-32-chars
