# ============================================================
# THE INDEPENDENCE LAW FIRM — CLIENT PORTAL
# Environment Variables — Copy to .env.local and fill in values
# NEVER commit .env.local to version control
# ============================================================

# ── Application ─────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-jwt-key-minimum-32-chars

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (Supabase, Neon, PlanetScale, etc.)
DATABASE_URL=postgresql://user:password@host:5432/independence_law_portal

# ── Email — Resend ───────────────────────────────────────────
# Replaces SMTP. All sending goes through Resend's API.
# Dashboard: https://resend.com/api-keys
# SECURITY: NEVER prefix with NEXT_PUBLIC_ — this is a server secret.
RESEND_API_KEY=re_CHANGE_ME_your_resend_api_key

# Verified "From" address (must match your Resend verified domain)
EMAIL_FROM=portal@theindependencelaw.com

# Reply-To address for client responses
EMAIL_REPLY_TO=support@theindependencelaw.com

# ── Email Verification ───────────────────────────────────────
# Token expiry in seconds (default: 86400 = 24 hours)
EMAIL_VERIFY_TOKEN_EXPIRY=86400

# ── Encryption ───────────────────────────────────────────────
# Used for hashing verification tokens
# Generate with: openssl rand -base64 32
TOKEN_SECRET=your-token-secret-for-verification-hashing

# ── Admin Authentication (Role-Isolated) ─────────────────────
# Admin credentials are NEVER stored in the database.
# Only hashed credentials are stored here in env vars.
#
# ADMIN_EMAIL: the administrator's login email
ADMIN_EMAIL=admin@theindependencelaw.com
#
# ADMIN_PASSWORD_HASH: bcrypt hash of the admin password (cost factor 12)
# Generate with:
#   node -e "require('bcryptjs').hash('your-strong-password', 12).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$12$CHANGE_ME_run_the_node_command_above_to_generate
#
# ADMIN_JWT_SECRET: signs admin session tokens — MUST be different from NEXTAUTH_SECRET
# A client token signed with NEXTAUTH_SECRET cannot access admin routes.
# Generate with: openssl rand -base64 32
ADMIN_JWT_SECRET=your-separate-admin-jwt-secret-minimum-32-chars

# ── AWS Backend (Isolated Node.js API) ───────────────────────
#
# NEXT_PUBLIC_AWS_API_URL: Base URL of the AWS API Gateway / backend service.
# NEXT_PUBLIC_ prefix is intentional — the URL is not sensitive and may be
# referenced by server components for display. The secret key below is what
# actually gates access.
NEXT_PUBLIC_AWS_API_URL=https://api.your-gateway.execute-api.us-east-1.amazonaws.com/prod

# AWS_API_SECRET: Bearer token sent in Authorization header to the backend.
# SECURITY: NEVER prefix with NEXT_PUBLIC_ — this is a server secret.
# This is the only credential the Next.js layer needs to reach the backend.
# Set the corresponding verification logic in your AWS Lambda / Node.js service.
# Generate with: openssl rand -base64 48
AWS_API_SECRET=your-aws-backend-bearer-token-minimum-48-chars

# ── AWS S3 (Document Storage) ────────────────────────────────
#
# S3_BUCKET_NAME: The S3 bucket that stores client documents.
# Not prefixed with NEXT_PUBLIC_ — bucket names are internal infrastructure.
# Presigned upload URLs are generated server-side via the AWS backend.
S3_BUCKET_NAME=independence-law-client-documents

# S3_BUCKET_REGION: AWS region of the bucket (used for presigned URL construction)
S3_BUCKET_REGION=us-east-1

# ── Security Checklist ───────────────────────────────────────
# Before deploying, confirm:
#   ✅ RESEND_API_KEY         — server-only (no NEXT_PUBLIC_)
#   ✅ AWS_API_SECRET         — server-only (no NEXT_PUBLIC_)
#   ✅ S3_BUCKET_NAME         — server-only (no NEXT_PUBLIC_)
#   ✅ ADMIN_PASSWORD_HASH    — server-only (no NEXT_PUBLIC_)
#   ✅ ADMIN_JWT_SECRET       — server-only (no NEXT_PUBLIC_)
#   ✅ NEXTAUTH_SECRET        — server-only (no NEXT_PUBLIC_)
#   ✅ TOKEN_SECRET           — server-only (no NEXT_PUBLIC_)
#   ⚠  NEXT_PUBLIC_AWS_API_URL — URL only, not a secret key
